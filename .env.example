# Copy this file to .env and supply your own Anthropic API key.
# Get one at https://console.anthropic.com/
#
# NOTE: This POC calls the Anthropic API directly from the browser for demo
# simplicity. That means the key is exposed to the client. This is fine for a
# local hackathon demo, but in production the call MUST be proxied through a
# backend so the key is never shipped to the browser.
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here